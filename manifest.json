{
  "manifest_version": 3,
  "name": "Desk Wellness Pack - Smart Stretch",
  "description": "Smart stretch reminders for healthier desk work habits.",
  "version": "1.5",
  "permissions": [
    "alarms",
    "storage",
    "idle",
    "identity"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://smart-stretch-backend.vercel.app/*"
  ],
  "oauth2": {
    "client_id": "750220805739-kuihv9grhjb9n66iqg8h52jr4c6anlrg.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.readonly"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/stretch-chime.mp3",
        "assets/stretch-chime.wav",
        "assets/notification.mp3",
        "assets/notification.wav",
        "chime.mp3",
        "libs/dotlottie-wc.lottie",
        "dotlottie-wc.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
